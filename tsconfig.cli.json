{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "./dist/cli",
    "rootDir": "./renderer",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "isolatedModules": true,
    "paths": {
      "@/*": ["./renderer/*"]
    }
  },
  "include": [
    "renderer/cli/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
