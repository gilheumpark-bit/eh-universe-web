{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/lib"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "excludePrivate": true,
  "excludeInternal": true,
  "readme": "none",
  "plugin": [],
  "categorizeByGroup": true,
  "name": "NOA Novel Studio API",
  "navigationLinks": {
    "GitHub": "https://github.com"
  },
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/node_modules/**"
  ],
  "tsconfig": "tsconfig.json",
  "skipErrorChecking": true,
  "validation": {
    "notExported": false,
    "invalidLink": false,
    "notDocumented": false
  }
}
