# Gemini CLI ignore — exclude heavy/generated paths from folder scans
# Mirrors .gitignore plus Nextron build outputs that slipped through

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/

# Build outputs
.next/
**/.next/
out/
**/out/
build/
dist/
**/dist/
.turbo/
**/.turbo/

# Nextron desktop build output (601MB / 21k files — main culprit)
apps/desktop/app/_next/
apps/desktop/app/**/*.js
apps/desktop/app/**/*.js.map
apps/desktop/app/**/*.LICENSE.txt
apps/desktop/app/**/*.html
apps/desktop/app/**/*.txt
apps/desktop/app/**/*.css
apps/desktop/app/**/*.woff
apps/desktop/app/**/*.woff2
apps/desktop/app/assets/
apps/desktop/app/_next/
apps/desktop/main/dist/
apps/desktop/preload/dist/
apps/desktop/renderer/.next/
apps/desktop/renderer/out/

# TypeScript build info
*.tsbuildinfo
**/*.tsbuildinfo

# Logs
*.log
**/*.log
build*.log
tsc_output.txt
error.txt
dev_electron_log.txt

# Coverage / test artifacts
coverage/
playwright-report/
test-results/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Env / secrets
.env*
!.env.example
*.key
*.pem
*credentials*.json
*service-account*.json

# Misc generated
competitor-analysis.html
lint_output.txt
ts_errors.txt
diff.txt
build_log.txt
*.bak
_backup*/
