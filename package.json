{
  "name": "eh-universe-web",
  "version": "1.2.1",
  "license": "CC-BY-NC-4.0",
  "private": true,
  "main": "app/main.js",
  "scripts": {
    "dev": "next dev renderer",
    "build": "next build renderer",
    "build:webpack": "next build renderer --webpack",
    "build:analyze": "cross-env ANALYZE=true next build renderer --webpack",
    "build:report": "node scripts/print-build-stats.mjs",
    "build:with-report": "npm run build && npm run build:report",
    "start": "next start renderer",
    "start:e2e": "next start renderer -p 3005",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:byok": "playwright test e2e/byok-api-settings-commercial.spec.ts",
    "test:e2e:byok:stress": "node scripts/e2e-commercial-stress.mjs",
    "test:e2e:byok:stress:smoke": "cross-env COMMERCIAL_E2E_TARGET_RUNS=60 node scripts/e2e-commercial-stress.mjs",
    "test:e2e:byok:stress:10k": "cross-env COMMERCIAL_E2E_TARGET_RUNS=10000 node scripts/e2e-commercial-stress.mjs",
    "verify:static": "npm run lint && node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --strict && npx jest --testPathPatterns=\"verification|composer-state|panel-registry|rate-limit|safe-fix|logger|server-ai\" --no-coverage",
    "verify:build": "npm run verify:static && npm run build",
    "verify": "npm run verify:build && npm run test:e2e",
    "integrity:scan": "node scripts/project-integrity-scan.mjs",
    "cs": "ts-node --project tsconfig.cli.json renderer/cli/bin/cs.ts",
    "cs:build": "tsc --project tsconfig.cli.json",
    "dev:electron": "nextron",
    "build:electron": "nextron build",
    "postinstall": "electron-builder install-app-deps"
  },
  "bin": {
    "cs": "./dist/cli/cli/bin/cs.js"
  },
  "dependencies": {
    "electron-serve": "^3.0.1",
    "framer-motion": "^12.38.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.49",
    "@google-cloud/discoveryengine": "^2.6.0",
    "@google/genai": "^1.47.0",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@monaco-editor/react": "^4.7.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@sentry/nextjs": "^10.46.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/analytics": "^2.0.1",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.142",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "epub2": "^3.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "firebase": "^12.11.0",
    "google-auth-library": "^10.6.2",
    "isomorphic-git": "^1.37.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "nextron": "^10.0.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "sql.js": "^1.14.1",
    "stripe": "^21.0.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-morph": "^23.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "zustand": "^5.0.12"
  },
  "build": {
    "asar": true,
    "win": {
      "target": "zip"
    },
    "forceCodeSigning": false
  }
}
