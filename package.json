{
  "name": "eh-universe-web",
  "version": "2.3.0-alpha",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "build:analyze": "cross-env ANALYZE=true next build --webpack",
    "build:report": "node scripts/print-build-stats.mjs",
    "build:with-report": "npm run build && npm run build:report",
    "bundle:report": "next build && node scripts/bundle-report.mjs",
    "lh:check": "node scripts/lighthouse-check.mjs",
    "start": "next start",
    "start:e2e": "next start -p 3005",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:scenarios": "playwright test e2e/scenarios",
    "test:e2e:byok": "playwright test e2e/byok-api-settings-commercial.spec.ts",
    "test:e2e:byok:stress": "node scripts/e2e-commercial-stress.mjs",
    "test:e2e:byok:stress:smoke": "cross-env COMMERCIAL_E2E_TARGET_RUNS=60 node scripts/e2e-commercial-stress.mjs",
    "test:e2e:byok:stress:10k": "cross-env COMMERCIAL_E2E_TARGET_RUNS=10000 node scripts/e2e-commercial-stress.mjs",
    "verify:static": "npm run lint && npx tsc --noEmit --strict && npx jest --testPathPatterns=\"verification|composer-state|panel-registry|rate-limit|safe-fix|logger|server-ai\" --no-coverage && npm run check:size:ci",
    "verify:build": "npm run verify:static && npm run build",
    "verify": "npm run verify:build && npm run test:e2e",
    "integrity:scan": "node scripts/project-integrity-scan.mjs",
    "check:size": "node scripts/check-file-size.mjs",
    "check:size:ci": "node scripts/check-file-size.mjs --ci",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "cs": "ts-node --project tsconfig.cli.json src/cli/bin/cs.ts",
    "cs:build": "tsc --project tsconfig.cli.json"
  },
  "bin": {
    "cs": "./dist/cli/cli/bin/cs.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.53",
    "@google-cloud/discoveryengine": "^2.6.0",
    "@google/genai": "^1.47.0",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/nextjs": "^10.46.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tiptap/extension-character-count": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vercel/analytics": "^2.0.1",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.142",
    "epub2": "^3.0.2",
    "fast-json-patch": "^3.1.1",
    "firebase": "^12.11.0",
    "google-auth-library": "^10.6.2",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.37.5",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.3",
    "octokit": "^5.0.5",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "sql.js": "^1.14.1",
    "stripe": "^21.0.1",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "dompurify": ">=3.3.2"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.2",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lighthouse": "^13.1.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-morph": "^23.0.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5"
  }
}
