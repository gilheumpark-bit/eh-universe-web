# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Electron / Nextron build outputs
/dist/
/app/main.js
/app/main.js.map
/app/preload.js
/app/preload.js.map
/main/dist/
/preload/dist/
/renderer/.next/
/renderer/out/
/renderer/build3.log

# Build logs
/build*.log
/out.log
/build_err.txt
/tsc-errors.txt
/verify_output.txt
/tmp_*.txt
/e2e_out*.log
/test_*.log
/test_frontend.log

# misc
.DS_Store
*.pem
build-performance-report.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SWC platform binaries (regenerated by npm ci)
.swc/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini

# test coverage
/coverage/

# Test artifacts
/playwright-report/
/test-results/

# General logs
*.log
.codex-*.log

# Competitor analysis (generated artifact)
competitor-analysis.html

# Binary documents (not suited for git)
*.docx

# One-off scripts (completed migrations)
scripts/migrate-*.mjs

# Claude Code
.claude/worktrees/
.env*.local

# Local IDE / agent state (do not commit)
.gemini/settings.local.json
.noa/sessions/

# Root scratch outputs (regenerate locally)
lint_output.txt
ts_errors.txt
diff.txt
split-out.txt
build_log.txt
build-analyze-log.txt
build-webpack-analyze-log.txt
build-webpack-analyze.txt
lint_report.json

# Security: keys, certs, credentials
*.key
*.p12
*.pfx
*credentials*.json
*service-account*.json
*.crt

# Backup files (should never be committed)
*.bak
_backup*/

# Database dumps
*.sql
*.dump

# Large test output
test-output*.log

# Temporary scripts
tmp-*.cjs
tmp-*.mjs
extract-*.js
patch*.js
run-audit*.ts
audit-report.txt

# Panic logs
next-panic-*.log

# Scratch / one-off outputs
auto-fix.js
check-lint.js
lint-results.json
out.txt
test.out
test2.out
test3.out
tmp/
