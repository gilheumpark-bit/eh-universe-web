# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
build-performance-report.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SWC platform binaries (regenerated by npm ci)
.swc/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini

# test coverage
/coverage/

# Test artifacts
/playwright-report/
/test-results/

# General logs
*.log
.codex-*.log

# Competitor analysis (generated artifact)
competitor-analysis.html

# Binary documents (not suited for git)
*.docx

# One-off scripts (completed migrations)
scripts/migrate-*.mjs

# Claude Code
.claude/worktrees/
.claude/settings.local.json
.env*.local

# Local IDE / agent state (do not commit)
.gemini/settings.local.json
.noa/sessions/

# Root scratch outputs (regenerate locally)
lint_output.txt
ts_errors.txt
diff.txt
split-out.txt
build_log.txt
build-analyze-log.txt
build-webpack-analyze-log.txt
build-webpack-analyze.txt
lint_report.json

# Security: keys, certs, credentials
*.key
*.p12
*.pfx
*credentials*.json
*service-account*.json
*.crt

# Backup files (should never be committed)
*.bak
_backup*/

# Database dumps
*.sql
*.dump

# Large test output
test-output*.log

# Temporary scripts
tmp-*.cjs
tmp-*.mjs
extract-*.js
patch*.js
run-audit*.ts
audit-report.txt

# Panic logs
next-panic-*.log

# Scratch / one-off outputs
auto-fix.js
check-lint.js
lint-results.json
out.txt
test.out
test2.out
test3.out
tmp/

# CS Quill local receipts
.cs/

# Playwright results
playwright-results.json

# Obsolete work orders
plans/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# TypeDoc API docs (regenerated locally)
docs/api/
.claude/
.tmp-*
fix-*.mjs

# Lighthouse local run output (매 실행 변동)
docs/lighthouse-report.md

# Playwright local run logs (루트 한정; e2e/ 디렉토리 소스는 제외 안 함)
/e2e*.log
