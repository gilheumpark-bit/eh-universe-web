// ============================================================
// EH Universe — Firestore Security Rules
// ============================================================
// DEPLOYMENT: This file must be manually deployed via Firebase CLI:
//   firebase deploy --only firestore:rules
//
// Or via Firebase Console > Firestore > Rules tab.
//
// These rules enforce:
//   - Authenticated writes only (no anonymous writes)
//   - Owner-only updates and deletes (ownerId/authorId must match auth.uid)
//   - Visibility-based read permissions per collection
//   - Data size guards to prevent oversized payloads
//   - Admin role escalation for settlements and reports
//   - Existence checks on all cross-document get() calls
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // PART 1 - SHARED HELPERS
    // ============================================================

    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && userDoc(request.auth.uid).exists()
        && userDoc(request.auth.uid).data.role == "admin";
    }

    function planetDoc(planetId) {
      return get(/databases/$(database)/documents/planets/$(planetId));
    }

    function isPlanetOwner(planetId) {
      return signedIn()
        && planetDoc(planetId).exists()
        && planetDoc(planetId).data.ownerId == request.auth.uid;
    }

    function canReadVisibility(visibility, ownerId) {
      return visibility == "public"
        || (visibility == "members" && signedIn())
        || (signedIn() && request.auth.uid == ownerId)
        || isAdmin();
    }

    // Safe planet-linked read: checks planet exists before accessing data
    function canReadByPlanet(planetId) {
      return planetDoc(planetId).exists()
        && canReadVisibility(planetDoc(planetId).data.visibility, planetDoc(planetId).data.ownerId);
    }

    // Safe post-linked read: checks post's planet chain exists
    function postDoc(postId) {
      return get(/databases/$(database)/documents/posts/$(postId));
    }

    // Data size guards — prevent oversized payloads from exhausting quota or storage
    function validPlanetData(d) {
      return d.name.size() <= 200
        && d.summary.size() <= 2000
        && d.representativeTags.size() <= 6
        && d.tags.size() <= 10
        && d.coreRules.size() <= 3;
    }

    function validPostData(d) {
      return d.title.size() <= 300
        && d.content.size() <= 50000
        && d.summary.size() <= 500
        && d.tags.size() <= 8;
    }

    function validCommentData(d) {
      return d.content.size() <= 5000;
    }

    function validReportData(d) {
      return d.detail.size() <= 2000;
    }

    // IDENTITY_SEAL: PART-1 | role=shared access helpers | inputs=auth and linked docs | outputs=booleans

    // ============================================================
    // PART 2 - COLLECTION RULES
    // ============================================================

    match /users/{uid} {
      // Profile read requires authentication to protect PII.
      // NOTE: If public profile display is needed, split into /users/{uid}/public subcollection.
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.id == uid
        && request.resource.data.role == "member";
      allow update: if signedIn()
        && (
          request.auth.uid == uid
          || isAdmin()
        );
      allow delete: if isAdmin();

      // Bookmarks subcollection — only the user themselves
      match /bookmarks/{bookmarkId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update: if signedIn() && request.auth.uid == uid;
        allow delete: if signedIn() && request.auth.uid == uid;
      }
    }

    match /planets/{planetId} {
      allow read: if canReadVisibility(resource.data.visibility, resource.data.ownerId);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == planetId
        && validPlanetData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || isAdmin()
        )
        && validPlanetData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || isAdmin()
        );

      // Planet-level comments subcollection
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && validCommentData(request.resource.data);
        allow update: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isPlanetOwner(planetId)
            || isAdmin()
          )
          && validCommentData(request.resource.data);
        allow delete: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isPlanetOwner(planetId)
            || isAdmin()
          );
      }

      // Planet-level reactions subcollection
      match /reactions/{reactionId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.userId == request.auth.uid;
        allow update: if false;
      }
    }

    match /posts/{postId} {
      // Safe read: verify linked planet exists before accessing its owner
      allow read: if planetDoc(resource.data.planetId).exists()
        && canReadVisibility(resource.data.visibility, planetDoc(resource.data.planetId).data.ownerId);
      allow create: if signedIn()
        && request.resource.data.id == postId
        && request.resource.data.authorId == request.auth.uid
        && (
          request.resource.data.planetId == ""
          || isPlanetOwner(request.resource.data.planetId)
          || isAdmin()
        )
        && validPostData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isPlanetOwner(resource.data.planetId)
          || isAdmin()
        )
        && validPostData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isPlanetOwner(resource.data.planetId)
          || isAdmin()
        );
    }

    match /settlements/{settlementId} {
      // Safe read: verify linked planet exists before accessing its data
      allow read: if canReadByPlanet(resource.data.planetId);
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      // Safe read: verify post exists, then verify its linked planet exists
      // get() calls are cached per rule evaluation — repeated calls to same path = 1 read
      allow read: if postDoc(resource.data.postId).exists()
        && planetDoc(postDoc(resource.data.postId).data.planetId).exists()
        && canReadVisibility(
          postDoc(resource.data.postId).data.visibility,
          planetDoc(postDoc(resource.data.postId).data.planetId).data.ownerId
        );
      allow create: if signedIn()
        && request.resource.data.id == commentId
        && request.resource.data.authorId == request.auth.uid
        && validCommentData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isAdmin()
        )
        && validCommentData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isAdmin()
        );
    }

    match /reactions/{reactionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Reports — authenticated users can create, only admin can read
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validReportData(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // IDENTITY_SEAL: PART-2 | role=collection policies | inputs=request and resource data | outputs=allow or deny
  }
}
