rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // PART 1 - SHARED HELPERS
    // ============================================================

    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && userDoc(request.auth.uid).exists()
        && userDoc(request.auth.uid).data.role == "admin";
    }

    function isPlanetOwner(planetId) {
      return signedIn()
        && get(/databases/$(database)/documents/planets/$(planetId)).exists()
        && get(/databases/$(database)/documents/planets/$(planetId)).data.ownerId == request.auth.uid;
    }

    function canReadVisibility(visibility, ownerId) {
      return visibility == "public"
        || (visibility == "members" && signedIn())
        || (signedIn() && request.auth.uid == ownerId)
        || isAdmin();
    }

    function linkedPlanet(postData) {
      return get(/databases/$(database)/documents/planets/$(postData.planetId));
    }

    // Data size guards — prevent oversized payloads from exhausting quota or storage
    function validPlanetData(d) {
      return d.name.size() <= 200
        && d.summary.size() <= 2000
        && d.representativeTags.size() <= 6
        && d.tags.size() <= 10
        && d.coreRules.size() <= 3;
    }

    function validPostData(d) {
      return d.title.size() <= 300
        && d.content.size() <= 50000
        && d.summary.size() <= 500
        && d.tags.size() <= 8;
    }

    function validCommentData(d) {
      return d.content.size() <= 5000;
    }

    function validReportData(d) {
      return d.detail.size() <= 2000;
    }

    // IDENTITY_SEAL: PART-1 | role=shared access helpers | inputs=auth and linked docs | outputs=booleans

    // ============================================================
    // PART 2 - COLLECTION RULES
    // ============================================================

    match /users/{uid} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.id == uid
        && request.resource.data.role == "member";
      allow update: if signedIn()
        && (
          request.auth.uid == uid
          || isAdmin()
        );
      allow delete: if isAdmin();

      // Bookmarks subcollection — only the user themselves
      match /bookmarks/{bookmarkId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update: if signedIn() && request.auth.uid == uid;
        allow delete: if signedIn() && request.auth.uid == uid;
      }
    }

    match /planets/{planetId} {
      allow read: if canReadVisibility(resource.data.visibility, resource.data.ownerId);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == planetId
        && validPlanetData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || isAdmin()
        )
        && validPlanetData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || isAdmin()
        );

      // Planet-level comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && validCommentData(request.resource.data);
        allow update: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isPlanetOwner(planetId)
            || isAdmin()
          )
          && validCommentData(request.resource.data);
        allow delete: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isPlanetOwner(planetId)
            || isAdmin()
          );
      }

      // Planet-level reactions subcollection
      match /reactions/{reactionId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.userId == request.auth.uid;
        allow update: if false;
      }
    }

    match /posts/{postId} {
      allow read: if canReadVisibility(resource.data.visibility, linkedPlanet(resource.data).data.ownerId);
      allow create: if signedIn()
        && request.resource.data.id == postId
        && request.resource.data.authorId == request.auth.uid
        && (
          isPlanetOwner(request.resource.data.planetId)
          || isAdmin()
        )
        && validPostData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isPlanetOwner(resource.data.planetId)
          || isAdmin()
        )
        && validPostData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isPlanetOwner(resource.data.planetId)
          || isAdmin()
        );
    }

    match /settlements/{settlementId} {
      allow read: if canReadVisibility(
        get(/databases/$(database)/documents/planets/$(resource.data.planetId)).data.visibility,
        get(/databases/$(database)/documents/planets/$(resource.data.planetId)).data.ownerId
      );
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if canReadVisibility(
        get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.visibility,
        get(/databases/$(database)/documents/planets/$(get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.planetId)).data.ownerId
      );
      allow create: if signedIn()
        && request.resource.data.id == commentId
        && request.resource.data.authorId == request.auth.uid
        && validCommentData(request.resource.data);
      allow update: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isAdmin()
        )
        && validCommentData(request.resource.data);
      allow delete: if signedIn()
        && (
          resource.data.authorId == request.auth.uid
          || isAdmin()
        );
    }

    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Reports — authenticated users can create, only admin can read
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validReportData(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // IDENTITY_SEAL: PART-2 | role=collection policies | inputs=request and resource data | outputs=allow or deny
  }
}
