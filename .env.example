# NOA Studio — Server-side API keys (optional, BYOK fallback)
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Firebase Authentication (required for Google login)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side aliases (used in API routes instead of NEXT_PUBLIC_ prefix)
FIREBASE_PROJECT_ID=
APP_VERSION=1.0.0

# Sentry Error Tracking (public DSN, safe for client-side)
SENTRY_DSN=

# Vertex AI Search — Network Agent (optional; ingest/search)
AGENT_BUILDER_NETWORK_ID=
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_CREDENTIALS=
AGENT_BUILDER_LOCATION=global
# Comma-separated Origins allowed to call /api/network-agent/* (e.g. EH Translator)
NETWORK_AGENT_CORS_ORIGINS=

# EH Translator — 별도 배포 URL(선택). 비우면 이 사이트의 /translation-studio (내장 번역 스튜디오)
NEXT_PUBLIC_EH_TRANSLATOR_ORIGIN=

# EH Translator 클라우드 동기화 (선택) — Supabase `eh_projects` 테이블
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# EH Translator — Stripe 결제(선택) /api/checkout
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# 번역 앱이 별도 도메인일 때만. 비우면 동일 사이트의 /api/network-agent/* 사용
NEXT_PUBLIC_EH_UNIVERSE_ORIGIN=
