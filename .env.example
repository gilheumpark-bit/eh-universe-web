# ============================================================
# EH Universe (Loreguard) — Environment Variables Template
# ============================================================
# 복사: cp .env.example .env.local
# 주의: .env.local 은 커밋 금지 (.gitignore 에 포함)
# 필수(*) / 선택(-) 표기 참고
# ============================================================

# ------------------------------------------------------------
# PART 1 — Firebase Authentication (* 필수: 로그인/인증)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# 서버 측 API 라우트에서 사용 (NEXT_PUBLIC_ 프리픽스 없이)
FIREBASE_PROJECT_ID=
APP_VERSION=2.1.0

# ------------------------------------------------------------
# PART 2 — AI Providers (* 최소 1개 필수, BYOK 폴백 지원)
# ------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
# Anthropic 공식 키 (CLAUDE_API_KEY 는 레거시 alias)
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ------------------------------------------------------------
# PART 3 — DGX Spark (- 선택: 로컬 추론 서버, 32B+1.5B Speculative)
# ------------------------------------------------------------
# Heavy 엔진: Qwen2.5-32B-Instruct-AWQ (구조화/장문)
NEXT_PUBLIC_SPARK_HEAVY_URL=http://localhost:8080
# Fast 엔진: Qwen2.5-1.5B Draft (스트리밍/인라인)
NEXT_PUBLIC_SPARK_FAST_URL=http://localhost:8081
# Vercel 배포 시 우회 URL (Cloudflare Tunnel 경유)
SPARK_SERVER_URL=

# ------------------------------------------------------------
# PART 4 — Vertex AI Search / Network Agent (- 선택)
# ------------------------------------------------------------
AGENT_BUILDER_NETWORK_ID=
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_CREDENTIALS=
AGENT_BUILDER_LOCATION=global
# /api/network-agent/* 호출 허용 Origin (comma-separated)
NETWORK_AGENT_CORS_ORIGINS=

# ------------------------------------------------------------
# PART 5 — Stripe 결제 (- 선택: OPEN_BETA=false 전환 시 필수)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------
# PART 6 — Supabase (- 선택: 번역 스튜디오 클라우드 동기화)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# PART 7 — Sentry 에러 트래킹 (- 선택: 프로덕션 권장)
# ------------------------------------------------------------
# 클라이언트 측 (public DSN)
NEXT_PUBLIC_SENTRY_DSN=
# 서버 측 (동일 DSN 사용 가능)
SENTRY_DSN=
# 트레이싱 샘플 비율 (0.0 ~ 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------------------------------------
# PART 8 — GitHub OAuth (- 선택: Studio GitHub 동기화)
# ------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------
# PART 9 — Cron / 보안 시크릿 (* 프로덕션 필수)
# ------------------------------------------------------------
# /api/cron/* 호출 인증 토큰
CRON_SECRET=

# ------------------------------------------------------------
# PART 10 — App / Origin (* 프로덕션 필수)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://eh-universe.com
# 번역 앱이 별도 도메인일 때만. 비우면 내장 /translation-studio 사용
NEXT_PUBLIC_EH_TRANSLATOR_ORIGIN=
# 번역 앱이 별도 도메인일 때만. 비우면 동일 사이트 /api/network-agent/* 사용
NEXT_PUBLIC_EH_UNIVERSE_ORIGIN=
