# ============================================================
# EH Universe (Loreguard) — Environment Variables Template
# ============================================================
# 복사: cp .env.example .env.local
# 주의: .env.local 은 커밋 금지 (.gitignore 에 포함)
# 필수(*) / 선택(-) 표기 참고
# ============================================================

# ------------------------------------------------------------
# PART 1 — Firebase Authentication (* 필수: 로그인/권한 확인)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# 로컬은 자동 same-origin auth 프록시 사용. 배포 도메인에서도 Firebase redirect 이슈가 있으면 true.
NEXT_PUBLIC_FIREBASE_AUTH_SAME_ORIGIN=false
# 서버 측 API 라우트에서 사용 (NEXT_PUBLIC_ 프리픽스 없이)
FIREBASE_PROJECT_ID=
APP_VERSION=2.1.0

# ------------------------------------------------------------
# PART 2 — AI Providers (* 최소 1개 필수, BYOK 폴백 지원)
# ------------------------------------------------------------
GEMINI_API_KEY=
UPSTAGE_API_KEY=
OPENAI_API_KEY=
# Anthropic 공식 키 (CLAUDE_API_KEY 는 레거시 alias)
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ------------------------------------------------------------
# PART 3 — DGX Spark (- 선택: 로컬 추론 서버)
# ------------------------------------------------------------
# 2026-04-20 업데이트: Qwen 3.6-35B-A3B-FP8 MoE 단일 장비 전환.
# FlashInfer + N-Gram Speculative Decoding 적용, 체감 40~50 tok/s.
#
# ── 엔드포인트 우선순위 ──
# 1. NEXT_PUBLIC_SPARK_GATEWAY_URL (명시) — 프로덕션 CF 게이트웨이 (있으면 우선)
# 2. SPARK_SERVER_URL (서버 측) — Vercel 서버 라우트에서 우회 경유
# 3. NEXT_PUBLIC_SPARK_SERVER_URL (클라이언트 측) — 브라우저 직접
# 4. 기본값 (dgx-models.ts): http://localhost:8000 (로컬 vLLM OpenAI 호환 서버 가정)
#
# 로컬 개발 (DGX 내부망 직결 시 자기 환경 IP로 교체):
SPARK_SERVER_URL=http://<DGX-SERVER-IP>:8000
NEXT_PUBLIC_SPARK_SERVER_URL=http://<DGX-SERVER-IP>:8000
# 프로덕션 (Cloudflare Tunnel 관통 후 재활성화 시):
# NEXT_PUBLIC_SPARK_GATEWAY_URL=https://api.ehuniverse.com

# vLLM 서빙 모델 ID — 서버의 --served-model-name 값과 일치 필수
VLLM_MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8
NEXT_PUBLIC_VLLM_MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8

# Legacy retrieval sidecar — Translation Studio 보강용. 창작 집필 경로에서는 사용하지 않음.
NEXT_PUBLIC_SPARK_RAG_URL=http://<DGX-SERVER-IP>:8082
# ComfyUI (Flux-Schnell FP8)
NEXT_PUBLIC_COMFYUI_URL=http://<DGX-SERVER-IP>:8188

# 레거시 — 9B 쌍포 시절 (하위 호환용, 사용 시 주석 해제)
# NEXT_PUBLIC_SPARK_HEAVY_URL=http://localhost:8080
# NEXT_PUBLIC_SPARK_FAST_URL=http://localhost:8081

# ------------------------------------------------------------
# PART 4 — Google 서비스 계정 (Firestore / Firebase Auth REST 공유)
# ------------------------------------------------------------
# [2026-06-06] Vertex AI Search / Network Agent(Discovery Engine) 경로 제거됨.
#   VERTEX_AI_CREDENTIALS 는 명칭과 달리 Firestore REST + Firebase Auth Admin(Stripe claim sync)
#   서비스 계정 JSON 으로 계속 사용됨 (동기화·저장·로그인). 이름은 하위호환 유지.
VERTEX_AI_CREDENTIALS=
# /api/network-agent/* (현재 비활성 — 항상 503) 호출 허용 Origin (comma-separated)
NETWORK_AGENT_CORS_ORIGINS=

# ------------------------------------------------------------
# PART 5 — Stripe 결제 (- 선택: OPEN_BETA=false 전환 시 필수)
# ------------------------------------------------------------
# M9 audit 기준 — webhook handler / publishable key 는 src/** 참조 0 건. 제거.
# 실제 사용: STRIPE_SECRET_KEY + NEXT_PUBLIC_STRIPE_PRICE_ID.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ------------------------------------------------------------
# PART 6 — Supabase (- 선택: 번역 스튜디오 클라우드 동기화)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# PART 7 — Sentry 에러 트래킹 (- 선택: 프로덕션 권장)
# ------------------------------------------------------------
# 클라이언트 측 (public DSN)
NEXT_PUBLIC_SENTRY_DSN=
# 서버 측 (동일 DSN 사용 가능)
SENTRY_DSN=
# 트레이싱 샘플 비율 (0.0 ~ 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------------------------------------
# PART 8 — GitHub OAuth (- 선택: Studio GitHub 동기화)
# ------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------
# PART 9 — Cron / 보안 시크릿 (* 프로덕션 필수)
# ------------------------------------------------------------
# /api/cron/* 호출 권한 토큰
CRON_SECRET=

# ------------------------------------------------------------
# PART 10 — App / Origin (* 프로덕션 필수)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://eh-universe.com
# 번역 앱이 별도 도메인일 때만. 비우면 내장 /translation-studio 사용
NEXT_PUBLIC_EH_TRANSLATOR_ORIGIN=
# 번역 앱이 별도 도메인일 때만. 비우면 동일 사이트 /api/network-agent/* 사용
NEXT_PUBLIC_EH_UNIVERSE_ORIGIN=

# ------------------------------------------------------------
# PART 11 — Route-level feature gates (- 선택, 기본 off)
# ------------------------------------------------------------
# [M9 audit P0-1] Stripe Checkout UI 가 붙기 전까지 /api/checkout 은 503.
# 'on' 으로 설정 시에만 엔드포인트 활성. 값: 'on' | 'off' (기본 off).
FEATURE_STRIPE_CHECKOUT=off
# 오디션/사전 이용 기간에는 공개 가격 숫자를 숨김. 공개 판매 전환 시에만 on.
NEXT_PUBLIC_SHOW_PUBLIC_PRICES=off
# [2026-06-06] Agent Builder(Vertex Discovery Engine) 제거됨 — /api/agent-search 는 항상 503.
# 이 플래그는 무의미(no-op)하나 하위호환을 위해 남겨둠.
FEATURE_AGENT_SEARCH=off

# ------------------------------------------------------------
# PART 12 — Translation registry flag (G4 — 2026-06-11)
# ------------------------------------------------------------
# 번역 stage 1~5·10 프롬프트에 writing-agent-registry 의 translator-* base
# (role·duty·가드·contextBlocks)를 prepend. 기본 on (미설정 = on).
# 출력 회귀 시 'off' 한 줄로 즉시 legacy prompt 롤백. 값: off | false | 0 → 비활성.
# NEXT_PUBLIC_TRANSLATOR_REGISTRY=off

# ------------------------------------------------------------
# PART 13 — 트랜잭션 이메일 (B1 — Resend REST)
# ------------------------------------------------------------
# 결제 영수증 · 결제실패 dunning · 계정삭제 통지 발송.
# 미설정 시 발송은 graceful no-op (warn 로그만, 흐름 차단 X) — 결제 OFF/테스트 환경 안전.
# 결제(FEATURE_STRIPE_CHECKOUT=on)를 켜기 전 반드시 설정할 것.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="Loreguard <no-reply@your-domain.com>"   # 인증된 발신 도메인 필요
# EMAIL_REPLY_TO=support@your-domain.com               # 선택 — 회신 주소
