{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "../_stubs/*": [
        "./lib/*"
      ],
      "@eh/quill-engine/types": [
        "../../../packages/quill-engine/src/types"
      ],
      "@eh/quill-engine/pipeline/*": [
        "../../../packages/quill-engine/src/pipeline/*"
      ]
    },
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "out/types/**/*.ts",
    "out/dev/types/**/*.ts",
    "../app/types/**/*.ts",
    "../app/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
