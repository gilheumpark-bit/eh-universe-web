{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "paths": {
      "@eh/shared-types": ["../shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../shared-types" }
  ]
}
